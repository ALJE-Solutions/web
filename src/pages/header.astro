<style>
.header {
  width: 100%;
  background: #fff;
  box-shadow: 0 2px 16px rgba(15,168,130,0.07);
  position: sticky;
  top: 0;
  z-index: 100;
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0.7rem 2.5rem;
}
.nav-brand {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}
.nav-brand img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #fff;
  object-fit: cover;
  box-shadow: 0 2px 8px rgba(15,168,130,0.10);
  transition: transform 0.2s;
}
.nav-brand img:hover {
  transform: scale(1.08) rotate(-6deg);
}
.nav-brand span {
  font-size: 1.7rem;
  font-weight: 900;
  letter-spacing: 2px;
  color: #0fa882;
  text-shadow: 0 2px 8px #e6f7f1;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 2.5rem;
  list-style: none;
  margin: 0;
  padding: 0;
  transition: gap 0.2s;
}
.nav-links li {
  display: flex;
  align-items: center;
}
.nav-links a {
  color: #0a2e1a;
  text-decoration: none;
  font-weight: 700;
  font-size: 1.08rem;
  letter-spacing: 1px;
  position: relative;
  padding: 0.2rem 0.1rem;
  border-radius: 6px;
  outline: none;
  transition: color 0.2s, background 0.2s;
}
.nav-links a:focus {
  box-shadow: 0 0 0 2px #0fa882;
  background: #e6f7f1;
}
.nav-links a::after {
  content: '';
  display: block;
  width: 0;
  height: 2px;
  background: #0fa882;
  transition: width 0.2s;
  margin: 0 auto;
}
.nav-links a:hover {
  color: #0a8a6a;
  background: #e6f7f1;
}
.nav-links a:hover::after {
  width: 100%;
}
.menu-toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  width: 38px;
  height: 38px;
  background: #e6f7f1;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  align-items: center;
  margin-left: 1.2rem;
  transition: background 0.2s;
}
.menu-toggle span {
  display: block;
  width: 24px;
  height: 3px;
  background: #0fa882;
  margin: 4px 0;
  border-radius: 2px;
  transition: all 0.3s;
}
@media (max-width: 900px) {
  .header-inner { padding: 0.7rem 1rem; }
  .nav-links { gap: 1.2rem; }
}
@media (max-width: 700px) {
  .nav-links {
    position: absolute;
    top: 64px;
    right: 0;
    background: #fff;
    flex-direction: column;
    align-items: flex-start;
    width: 220px;
    box-shadow: 0 8px 32px rgba(15,168,130,0.13);
    border-radius: 0 0 0 16px;
    padding: 1.2rem 1.2rem 1.2rem 1.5rem;
    gap: 1.2rem;
    display: none;
  }
  .nav-links.open {
    display: flex;
  }
  .menu-toggle {
    display: flex;
  }
}
</style>

<script>
  let menuOpen = false;
  function toggleMenu() {
    menuOpen = !menuOpen;
    const navLinks = document.querySelector('.nav-links');
    if (navLinks) {
      if (menuOpen) navLinks.classList.add('open');
      else navLinks.classList.remove('open');
    }
  }
</script>

<header class="header">
  <div class="header-inner">
    <div class="nav-brand">
      <img src="/src/images/logo_sinfondo.png" alt="Logo ALJE Solutions" />
      <span>ALJE Solutions</span>
    </div>
    <button class="menu-toggle" aria-label="Abrir menú" onclick="toggleMenu()">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="nav-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/nosotros">Nosotros</a></li>
      <li><a href="/servicios">Servicios</a></li>
      <li><a href="/packs">Packs</a></li>
      <li><a href="/ejemplos">Nuestros Trabajos</a></li>
      <li><a href="/contacto">Contacto</a></li>
    </ul>
  </div>
</header>
