<style>
.header {
  width: 100%;
  background: transparent;
  position: fixed;
  top: 0;
  left: 0;
  z-index: 200;
  transition: background 0.35s ease, box-shadow 0.35s ease, padding 0.3s ease;
}
.header.scrolled {
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(14px);
  box-shadow: 0 2px 24px rgba(10,25,47,0.08);
  border-bottom: 1px solid rgba(10,25,47,0.06);
}
.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.2rem 2.5rem;
  transition: padding 0.3s ease;
}
.header.scrolled .header-inner {
  padding: 0.65rem 2.5rem;
}
.nav-brand {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}
.nav-brand img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: transparent;
  object-fit: cover;
  transition: transform 0.2s, filter 0.3s;
  filter: brightness(10);
}
.header.scrolled .nav-brand img {
  filter: none;
}
.nav-brand img:hover {
  transform: scale(1.08) rotate(-6deg);
}
.nav-brand span {
  font-size: 1.5rem;
  font-weight: 900;
  letter-spacing: 2px;
  color: #ffffff;
  transition: color 0.35s;
}
.header.scrolled .nav-brand span {
  color: #0a192f;
}
.nav-links {
  display: flex;
  align-items: center;
  gap: 2.2rem;
  list-style: none;
  margin: 0;
  padding: 0;
}
.nav-links li {
  display: flex;
  align-items: center;
}
.nav-links a {
  color: rgba(255,255,255,0.88);
  text-decoration: none;
  font-weight: 600;
  font-size: 0.95rem;
  letter-spacing: 0.5px;
  position: relative;
  padding: 0.3rem 0.1rem;
  border-radius: 6px;
  outline: none;
  transition: color 0.2s;
}
.header.scrolled .nav-links a {
  color: #333;
}
.nav-links a:focus {
  box-shadow: 0 0 0 2px #0fa882;
}
.nav-links a::after {
  content: '';
  display: block;
  width: 0;
  height: 2px;
  background: #0fa882;
  transition: width 0.25s;
  margin: 2px auto 0;
}
.nav-links a:hover {
  color: #0fa882;
}
.nav-links a:hover::after {
  width: 100%;
}
.nav-cta {
  background: #0fa882;
  color: #fff !important;
  padding: 0.55rem 1.3rem !important;
  border-radius: 8px;
  font-weight: 700 !important;
  transition: background 0.2s, transform 0.2s;
}
.nav-cta:hover {
  background: #0a8a6a;
  color: #fff !important;
  transform: translateY(-1px);
}
.nav-cta::after {
  display: none !important;
}
.menu-toggle {
  display: none;
  flex-direction: column;
  justify-content: center;
  width: 38px;
  height: 38px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.22);
  border-radius: 8px;
  cursor: pointer;
  align-items: center;
  margin-left: 1.2rem;
  transition: background 0.2s, border 0.2s;
}
.header.scrolled .menu-toggle {
  background: #f0faf6;
  border-color: rgba(15,168,130,0.18);
}
.menu-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: #ffffff;
  margin: 3px 0;
  border-radius: 2px;
  transition: all 0.3s;
}
.header.scrolled .menu-toggle span {
  background: #0fa882;
}
@media (max-width: 900px) {
  .header-inner { padding: 1rem 1.5rem; }
  .header.scrolled .header-inner { padding: 0.65rem 1.5rem; }
  .nav-links { gap: 1.2rem; }
}
@media (max-width: 700px) {
  .nav-brand span {
    font-size: 1.15rem;
    letter-spacing: 1px;
  }
  .nav-brand img {
    width: 32px;
    height: 32px;
  }
  .menu-toggle {
    display: flex;
  }
  .nav-links {
    position: fixed;
    top: 0;
    right: -280px;
    bottom: 0;
    background: #0a192f;
    flex-direction: column;
    align-items: flex-start;
    width: 260px;
    box-shadow: -8px 0 40px rgba(0,0,0,0.3);
    padding: 5.5rem 1.8rem 2rem;
    gap: 0;
    display: flex;
    transition: right 0.35s cubic-bezier(.4,0,.2,1);
  }
  .nav-links.open { right: 0; }
  .nav-links a {
    color: rgba(255,255,255,0.85) !important;
    font-size: 1.05rem;
    padding: 0.9rem 0;
    width: 100%;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .nav-links a::after { display: none; }
  .nav-cta {
    margin-top: 1.2rem;
    display: block;
    text-align: center;
    background: #0fa882 !important;
    border-radius: 8px !important;
    padding: 0.7rem 1rem !important;
  }
}
</style>

<script>
  const header = document.querySelector('.header');

  // Scroll detection: transparent → white
  function onScroll() {
    if (window.scrollY > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  }
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  let menuOpen = false;

  function toggleMenu() {
    menuOpen = !menuOpen;
    const navLinks = document.querySelector('.nav-links');
    if (navLinks) {
      if (menuOpen) navLinks.classList.add('open');
      else navLinks.classList.remove('open');
    }
  }

  // Asignar evento al botón hamburguesa
  const menuBtn = document.querySelector('.menu-toggle');
  if (menuBtn) {
    menuBtn.addEventListener('click', toggleMenu);
  }

  // Cerrar menú al hacer clic en un enlace (móvil)
  document.querySelectorAll('.nav-links a').forEach(function(link) {
    link.addEventListener('click', function() {
      menuOpen = false;
      const navLinks = document.querySelector('.nav-links');
      if (navLinks) navLinks.classList.remove('open');
    });
  });
</script>

<header class="header">
  <div class="header-inner">
    <div class="nav-brand">
      <img src="/logo_sinfondo.png" alt="Logo ALJE Solutions" />
      <span>ALJE Solutions</span>
    </div>
    <button class="menu-toggle" aria-label="Abrir menú">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul class="nav-links">
      <li><a href="#inicio">Inicio</a></li>
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#nosotros">Nosotros</a></li>
      <li><a href="#portfolio">Portfolio</a></li>
      <li><a href="#contacto" class="nav-cta">Contacto</a></li>
    </ul>
  </div>
</header>
