---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="ALJE Solutions — Desarrollo Web y Soluciones Digitales a Medida"
  description="Agencia de desarrollo web, consultoría IT y automatización para empresas en España. Creamos páginas web, tiendas online y soluciones digitales a medida para impulsar tu negocio."
>

	<!-- ═══════════════ HERO ═══════════════ -->
	<section id="inicio" class="hero">
		<div class="hero-bg"></div>
		<div class="hero-content">
			<p class="hero-tag">SOLUCIONES DIGITALES A MEDIDA</p>
			<h1>Impulsamos tu negocio con <span class="accent">tecnología</span></h1>
			<p class="hero-sub">Desarrollo web, consultoría IT y automatización para empresas que quieren crecer en el mundo digital.</p>
			<div class="hero-btns">
				<a href="#contacto" class="btn-primary">Solicitar presupuesto</a>
				<a href="#servicios" class="btn-secondary">Nuestros servicios</a>
			</div>
		</div>
	</section>

	<!-- ═══════════════ SECTORES / SLIDER ═══════════════ -->
	<section class="sectors">
		<p class="section-tag">¿A QUIÉN AYUDAMOS?</p>
		<h2 class="section-title">Soluciones digitales para todo tipo de negocios</h2>

		<div class="slider-wrapper">
			<button class="slider-arrow slider-arrow-left" id="sectorPrev" aria-label="Anterior">&#8249;</button>
			<div class="slider-viewport">
				<div class="slider-track" id="sectorSlider">
				<div class="slider-slide">
					<div class="slide-icon">🏪</div>
					<h3>Comercios locales</h3>
					<p>Tiendas, boutiques y negocios de barrio que quieren vender online y atraer más clientes.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">🍽️</div>
					<h3>Restauración y hostelería</h3>
					<p>Restaurantes, bares y cafeterías con carta digital, reservas online y presencia profesional.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">⚕️</div>
					<h3>Clínicas y salud</h3>
					<p>Clínicas dentales, fisioterapeutas y centros de salud con sistema de citas y visibilidad online.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">🏋️</div>
					<h3>Gimnasios y deporte</h3>
					<p>Centros deportivos y entrenadores personales con reservas de clases y gestión de socios.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">🏠</div>
					<h3>Inmobiliarias</h3>
					<p>Agencias y portales de propiedades con catálogo de inmuebles, filtros y formularios de contacto.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">💼</div>
					<h3>Consultorías y asesorías</h3>
					<p>Despachos profesionales que necesitan proyectar confianza y captar clientes online.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">🎓</div>
					<h3>Educación y formación</h3>
					<p>Academias, centros de formación y profesores con plataformas de cursos y matriculación.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">✂️</div>
					<h3>Peluquerías y estética</h3>
					<p>Salones de belleza y centros de estética con citas online y catálogo de servicios.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">🚗</div>
					<h3>Talleres y automoción</h3>
					<p>Talleres mecánicos y concesionarios con gestión de citas, presupuestos y catálogo de vehículos.</p>
				</div>
				<div class="slider-slide">
					<div class="slide-icon">🛍️</div>
					<h3>E-commerce y startups</h3>
					<p>Nuevos proyectos digitales y tiendas online que necesitan despegar con fuerza desde el primer día.</p>
				</div>
				</div>
			</div>
			<button class="slider-arrow slider-arrow-right" id="sectorNext" aria-label="Siguiente">&#8250;</button>
		</div>

		<div class="slider-counter" id="sliderCounter">1 / 10</div>
	</section>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			/* ——— Función genérica para crear un slider tipo libro ——— */
			function createBookSlider(config) {
				const track = document.getElementById(config.trackId);
				const prevBtn = document.getElementById(config.prevId);
				const nextBtn = document.getElementById(config.nextId);
				const counterEl = config.counterId ? document.getElementById(config.counterId) : null;
				if (!track || !prevBtn || !nextBtn) return;

				const slides = track.querySelectorAll(config.slideSelector);
				const total = slides.length;
				let current = 0;
				let timer = null;

				function getPerView() {
					if (!config.perView) return 1;
					const w = window.innerWidth;
					if (w <= 600) return config.perView.mobile || 1;
					if (w <= 900) return config.perView.tablet || 2;
					return config.perView.desktop || 3;
				}

				function getMaxPage() {
					return Math.max(0, total - getPerView());
				}

				function goTo(i) {
					const max = getMaxPage();
					if (i > max) i = 0;
					if (i < 0) i = max;
					current = i;
					const pv = getPerView();
					const shift = (100 / pv) * current;
					track.style.transform = 'translateX(-' + shift + '%)';
					if (counterEl) {
						const currentPage = Math.floor(current / pv) + 1;
						const totalPages = Math.ceil(total / pv);
						counterEl.textContent = currentPage + ' / ' + totalPages;
					}
				}

				function step() {
					const pv = getPerView();
					goTo(current + pv);
				}

				function stepBack() {
					const pv = getPerView();
					goTo(current - pv);
				}

				function startAuto() {
					stopAuto();
					if (config.autoplay) {
						timer = setInterval(function() { step(); }, config.autoplay);
					}
				}

				function stopAuto() {
					if (timer) { clearInterval(timer); timer = null; }
				}

				prevBtn.addEventListener('click', function() { stepBack(); stopAuto(); startAuto(); });
				nextBtn.addEventListener('click', function() { step(); stopAuto(); startAuto(); });

				// Swipe táctil
				let startX = 0;
				track.addEventListener('touchstart', function(e) {
					startX = e.changedTouches[0].screenX; stopAuto();
				}, { passive: true });
				track.addEventListener('touchend', function(e) {
					const diff = startX - e.changedTouches[0].screenX;
					if (Math.abs(diff) > 50) {
						if (diff > 0) step(); else stepBack();
					}
					startAuto();
				}, { passive: true });

				// Pausar al hacer hover
				const wrapper = track.closest('.slider-wrapper') || track.parentElement;
				if (wrapper) {
					wrapper.addEventListener('mouseenter', stopAuto);
					wrapper.addEventListener('mouseleave', startAuto);
				}

				// Ajustar slide widths para multi-view
				function applyWidths() {
					const pv = getPerView();
					slides.forEach(function(s) {
						s.style.minWidth = (100 / pv) + '%';
					});
					if (current > getMaxPage()) current = getMaxPage();
					goTo(current);
				}

				let resizeT;
				window.addEventListener('resize', function() {
					clearTimeout(resizeT);
					resizeT = setTimeout(applyWidths, 150);
				});

				// Init
				applyWidths();
				startAuto();
			}

			/* ——— Slider de Sectores (1 por página) ——— */
			createBookSlider({
				trackId: 'sectorSlider',
				prevId: 'sectorPrev',
				nextId: 'sectorNext',
				counterId: 'sliderCounter',
				slideSelector: '.slider-slide',
				autoplay: 5000
			});
		});
	</script>

	<!-- ═══════════════ SERVICIOS ═══════════════ -->
	<section id="servicios" class="section">
		<p class="section-tag">NUESTROS SERVICIOS</p>
		<h2 class="section-title">Soluciones digitales para cada etapa de tu negocio</h2>
		<p class="section-sub">Ofrecemos servicios integrales para potenciar tu presencia digital y hacer crecer tu negocio.</p>

		<div class="services-grid">
			<div class="service-card">
				<div class="service-icon">🌐</div>
				<h3>Desarrollo Web</h3>
				<p>Sitios web modernos, responsivos y optimizados para buscadores que destacan en el mercado digital.</p>
				<ul class="service-features">
					<li>Diseño web responsive</li>
					<li>Optimización SEO</li>
					<li>Integración con CMS</li>
				</ul>
			</div>
			<div class="service-card">
				<div class="service-icon">🛒</div>
				<h3>Tiendas Online</h3>
				<p>E-commerce completo con pasarelas de pago seguras, gestión de inventario y experiencia de compra optimizada.</p>
				<ul class="service-features">
					<li>Pasarelas de pago</li>
					<li>Gestión de inventario</li>
					<li>Diseño UX orientado a conversión</li>
				</ul>
			</div>
			<div class="service-card">
				<div class="service-icon">💡</div>
				<h3>Consultoría IT</h3>
				<p>Asesoría tecnológica para optimizar procesos y adoptar las herramientas digitales que tu negocio necesita.</p>
				<ul class="service-features">
					<li>Análisis de necesidades</li>
					<li>Transformación digital</li>
					<li>Optimización de procesos</li>
				</ul>
			</div>
			<div class="service-card">
				<div class="service-icon">⚙️</div>
				<h3>Automatización</h3>
				<p>Soluciones inteligentes de automatización para liberar tiempo y aumentar la productividad de tu equipo.</p>
				<ul class="service-features">
					<li>Automatización de flujos</li>
					<li>Integración de sistemas</li>
					<li>Informes automáticos</li>
				</ul>
			</div>
		</div>
	</section>

	<!-- ═══════════════ PACKS ═══════════════ -->
	<section id="packs" class="section section-alt">
		<p class="section-tag">PLANES</p>
		<h2 class="section-title">Elige el plan que mejor se adapte a ti</h2>
		<p class="section-sub">Desde una landing page hasta una plataforma completa, tenemos la solución para tu proyecto.</p>

		<div class="packs-grid">
			<div class="pack-card">
				<div class="pack-header esencial-bg">
					<span class="pack-name">Esencial</span>
				</div>
				<p class="pack-desc">Solución rápida y efectiva para tener presencia online y captar clientes.</p>
				<ul class="pack-features">
					<li>Landing Page optimizada para conversión</li>
					<li>Diseño responsive (móvil, tablet, desktop)</li>
					<li>Secciones básicas (hero, servicios, contacto)</li>
					<li>Formulario de contacto + WhatsApp</li>
					<li>SEO básico y entrega rápida</li>
				</ul>
				<p class="pack-ideal">Ideal para pequeños negocios y validación de ideas.</p>
				<a href="#contacto" class="btn-pack esencial-btn">Solicitar presupuesto</a>
			</div>

			<div class="pack-card pack-featured">
				<div class="pack-popular">Más popular</div>
				<div class="pack-header profesional-bg">
					<span class="pack-name">Profesional</span>
				</div>
				<p class="pack-desc">Web completa para empresas que buscan presencia sólida y profesional.</p>
				<ul class="pack-features">
					<li>Web corporativa multi-página</li>
					<li>Diseño personalizado (UX/UI)</li>
					<li>Optimización SEO avanzada</li>
					<li>Sistema autogestionable (CMS)</li>
					<li>Integración con herramientas externas</li>
				</ul>
				<p class="pack-ideal">Ideal para empresas y negocios en crecimiento.</p>
				<a href="#contacto" class="btn-pack profesional-btn">Solicitar presupuesto</a>
			</div>

			<div class="pack-card">
				<div class="pack-header premium-bg">
					<span class="pack-name">Premium</span>
				</div>
				<p class="pack-desc">Solución avanzada con funcionalidades completas y orientada a la escalabilidad.</p>
				<ul class="pack-features">
					<li>Ecommerce o plataforma avanzada</li>
					<li>Sistema de reservas personalizado</li>
					<li>Área privada / usuarios</li>
					<li>Integraciones externas (APIs, pagos)</li>
					<li>Analítica avanzada y seguridad reforzada</li>
				</ul>
				<p class="pack-ideal">Ideal para tiendas online y negocios digitales.</p>
				<a href="#contacto" class="btn-pack premium-btn">Solicitar presupuesto</a>
			</div>
		</div>
	</section>

	<!-- ═══════════════ NOSOTROS ═══════════════ -->
	<section id="nosotros" class="section">
		<p class="section-tag">¿QUIÉNES SOMOS?</p>
		<h2 class="section-title">Transformamos tu visión en realidad digital</h2>
		<p class="section-sub">En ALJE Solutions combinamos creatividad, experiencia técnica y estrategia de negocio para crear soluciones digitales que impulsan el crecimiento de tu empresa.</p>

		<div class="about-grid">
			<div class="about-card">
				<div class="about-icon">🎯</div>
				<h3>Enfoque personalizado</h3>
				<p>Cada proyecto es único. Trabajamos contigo para entender tus necesidades y crear soluciones a medida.</p>
			</div>
			<div class="about-card">
				<div class="about-icon">🚀</div>
				<h3>Tecnología de vanguardia</h3>
				<p>Utilizamos las últimas tecnologías para garantizar que tu proyecto sea robusto, escalable y preparado para el futuro.</p>
			</div>
			<div class="about-card">
				<div class="about-icon">🤝</div>
				<h3>Comunicación constante</h3>
				<p>Mantenemos comunicación fluida durante todo el proceso, asegurándonos de que estés informado en cada etapa.</p>
			</div>
			<div class="about-card">
				<div class="about-icon">📊</div>
				<h3>Resultados medibles</h3>
				<p>Nos enfocamos en métricas reales y resultados tangibles que demuestran el impacto de nuestro trabajo.</p>
			</div>
		</div>
	</section>

	<!-- ═══════════════ PROCESO ═══════════════ -->
	<section id="proceso" class="section section-alt">
		<p class="section-tag">NUESTRO PROCESO</p>
		<h2 class="section-title">Cómo trabajamos</h2>
		<p class="section-sub">Un proceso ágil y transparente para que tu proyecto sea un éxito desde el primer día.</p>

		<div class="process-grid">
			<div class="process-step">
				<div class="step-number">1</div>
				<h3>Análisis</h3>
				<p>Escuchamos tus necesidades y analizamos tu situación para ofrecerte la mejor solución posible.</p>
			</div>
			<div class="process-step">
				<div class="step-number">2</div>
				<h3>Propuesta</h3>
				<p>Te presentamos una propuesta clara, detallada y adaptada a tus objetivos y presupuesto.</p>
			</div>
			<div class="process-step">
				<div class="step-number">3</div>
				<h3>Desarrollo</h3>
				<p>Desarrollamos e implementamos la solución, manteniéndote informado en cada paso del camino.</p>
			</div>
			<div class="process-step">
				<div class="step-number">4</div>
				<h3>Soporte</h3>
				<p>Te acompañamos después de la entrega para asegurar el éxito y resolver cualquier duda.</p>
			</div>
		</div>
	</section>

	<!-- ═══════════════ CONTACTO ═══════════════ -->
	<section id="contacto" class="section">
		<p class="section-tag">CONTACTO</p>
		<h2 class="section-title">¿Listo para impulsar tu negocio?</h2>
		<p class="section-sub">Cuéntanos sobre tu proyecto y te responderemos lo antes posible.</p>

		<div class="contact-grid">
			<div class="contact-info">
				<div class="contact-item">
					<div class="contact-icon">📧</div>
					<div>
						<h4>Email</h4>
						<a href="mailto:aljesolutions@gmail.com">aljesolutions@gmail.com</a>
					</div>
				</div>
				<div class="contact-item">
					<div class="contact-icon">📍</div>
					<div>
						<h4>Ubicación</h4>
						<span>España</span>
					</div>
				</div>
			</div>

			<form class="contact-form" action="https://formsubmit.co/aljesolutions@gmail.com" method="POST">
				<input type="hidden" name="_subject" value="Nuevo mensaje desde la web de ALJE Solutions">
				<input type="hidden" name="_captcha" value="true">
				<input type="hidden" name="_template" value="table">
				<input type="text" name="_honey" style="display:none">

				<div class="form-row">
					<div class="form-group">
						<label for="nombre">Nombre</label>
						<input type="text" id="nombre" name="nombre" required placeholder="Tu nombre" />
					</div>
					<div class="form-group">
						<label for="email">Correo electrónico</label>
						<input type="email" id="email" name="email" required placeholder="tu@email.com" />
					</div>
				</div>
				<div class="form-group">
					<label for="asunto">Asunto</label>
					<input type="text" id="asunto" name="asunto" placeholder="¿En qué podemos ayudarte?" />
				</div>
				<div class="form-group">
					<label for="mensaje">Mensaje</label>
					<textarea id="mensaje" name="mensaje" rows="5" required placeholder="Describe tu proyecto o consulta..."></textarea>
				</div>
				<button type="submit" class="btn-primary btn-submit">Enviar mensaje</button>
			</form>
		</div>
	</section>

</Layout>

<style>
/* ═══════════ GENERAL ═══════════ */
.section {
	max-width: 1100px;
	margin: 0 auto;
	padding: 6rem 2rem;
	position: relative;
}
.section::before {
	content: '';
	position: absolute;
	top: 0;
	bottom: 0;
	left: 50%;
	transform: translateX(-50%);
	width: 100vw;
	background:
		radial-gradient(ellipse at 15% 30%, rgba(15,168,130,0.05) 0%, transparent 55%),
		radial-gradient(ellipse at 85% 70%, rgba(15,168,130,0.04) 0%, transparent 50%);
	pointer-events: none;
	z-index: 0;
}
.section > * {
	position: relative;
	z-index: 1;
}
.section-alt {
	background: #f5f7fa;
	max-width: 100%;
	padding-left: 0;
	padding-right: 0;
}
.section-alt::before {
	display: none;
}
.section-alt > * {
	max-width: 1100px;
	margin-left: auto;
	margin-right: auto;
	padding-left: 2rem;
	padding-right: 2rem;
}
.section-tag {
	color: #0fa882;
	font-size: 0.85rem;
	font-weight: 700;
	letter-spacing: 2.5px;
	text-transform: uppercase;
	text-align: center;
	margin-bottom: 0.8rem;
}
.section-title {
	color: #0a192f;
	font-size: 2.4rem;
	font-weight: 800;
	text-align: center;
	margin-bottom: 0.8rem;
	letter-spacing: 0.5px;
}
.section-sub {
	color: #555;
	font-size: 1.1rem;
	text-align: center;
	max-width: 600px;
	margin: 0 auto 3.5rem;
	line-height: 1.7;
}
.accent { color: #0fa882; }

/* ═══════════ SECTORS SLIDER ═══════════ */
.sectors {
	background: #f5f7fa;
	padding: 5rem 0 4rem;
	overflow: hidden;
}
.sectors .section-tag,
.sectors .section-title {
	padding: 0 2rem;
}
.sectors .section-title {
	margin-bottom: 3rem;
}

/* ——— Shared slider (used by sectors + portfolio) ——— */
.slider-wrapper {
	position: relative;
	max-width: 800px;
	margin: 0 auto;
	padding: 0 3rem;
}
.slider-viewport {
	overflow: hidden;
	border-radius: 16px;
}
.slider-track {
	display: flex;
	transition: transform 0.5s cubic-bezier(.4,0,.2,1);
}
.slider-arrow {
	position: absolute;
	top: 50%;
	transform: translateY(-50%);
	z-index: 5;
	width: 44px;
	height: 44px;
	border-radius: 50%;
	border: none;
	background: rgba(255,255,255,0.95);
	box-shadow: 0 2px 12px rgba(10,25,47,0.12);
	color: #0a192f;
	font-size: 1.6rem;
	font-weight: 300;
	cursor: pointer;
	display: flex;
	align-items: center;
	justify-content: center;
	transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
	line-height: 1;
	padding: 0;
}
.slider-arrow:hover {
	background: #0fa882;
	color: #fff;
	transform: translateY(-50%) scale(1.08);
	box-shadow: 0 4px 16px rgba(15,168,130,0.3);
}
.slider-arrow-left {
	left: -8px;
}
.slider-arrow-right {
	right: -8px;
}
.slider-counter {
	display: none;
}

/* ——— Sector slides ——— */
.slider-slide {
	min-width: 100%;
	box-sizing: border-box;
	flex-shrink: 0;
}
.slider-slide > .slide-icon {
	font-size: 3rem;
	background: #fff;
	padding: 2.5rem 2rem 0;
	border-radius: 16px 16px 0 0;
	margin: 0;
	text-align: center;
}
.slider-slide h3 {
	color: #0a192f;
	font-size: 1.4rem;
	font-weight: 800;
	background: #fff;
	padding: 1rem 2rem 0.4rem;
	margin: 0;
	text-align: center;
}
.slider-slide p {
	color: #555;
	font-size: 1.05rem;
	line-height: 1.7;
	background: #fff;
	padding: 0 2rem 2.5rem;
	border-radius: 0 0 16px 16px;
	margin: 0;
	text-align: center;
}

@media (max-width: 600px) {
	.sectors {
		padding: 4rem 0 3rem;
	}
	.slider-wrapper {
		padding: 0 2.5rem;
	}
	.slider-arrow {
		width: 34px;
		height: 34px;
		font-size: 1.2rem;
	}
	.slider-arrow-left { left: -2px; }
	.slider-arrow-right { right: -2px; }
	.slider-slide > .slide-icon {
		font-size: 2.5rem;
		padding: 2rem 1.5rem 0;
	}
	.slider-slide h3 {
		font-size: 1.2rem;
		padding: 0.8rem 1.5rem 0.3rem;
	}
	.slider-slide p {
