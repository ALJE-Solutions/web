	<script>
		const words = [
			'restaurante', 'clínica', 'gimnasio', 'inmobiliaria',
			'peluquería', 'taller', 'academia', 'comercio', 'startup', 'asesoría'
		];
		const elCode  = document.getElementById('codeTypewriter')   as HTMLElement | null;
		let wi = 0, ci = 0, deleting = false;
		function tick() {
			const word = words[wi];
			const text = deleting ? word.slice(0, --ci) : word.slice(0, ++ci);
			if (elCode)  elCode.textContent  = text;
			if (!deleting && ci === word.length) {
				deleting = true; setTimeout(tick, 1800); return;
			}
			if (deleting && ci === 0) {
				deleting = false; wi = (wi + 1) % words.length; setTimeout(tick, 300); return;
			}
			setTimeout(tick, deleting ? 45 : 80);
		}
		setTimeout(tick, 800);
	</script>

	<script>
		document.addEventListener('DOMContentLoaded', () => {
			/* ——— Función genérica para crear un slider tipo libro ——— */
			function createBookSlider(config: {
				trackId: string;
				prevId: string;
				nextId: string;
				counterId?: string;
				slideSelector: string;
				perView?: { mobile?: number; tablet?: number; desktop?: number };
				autoplay?: number;
			}) {
				const track = document.getElementById(config.trackId) as HTMLElement | null;
				const prevBtn = document.getElementById(config.prevId);
				const nextBtn = document.getElementById(config.nextId);
				const counterEl = config.counterId ? document.getElementById(config.counterId) : null;
				if (!track || !prevBtn || !nextBtn) return;

				const slides = track.querySelectorAll<HTMLElement>(config.slideSelector);
				const total = slides.length;
				let current = 0;
				let timer: ReturnType<typeof setInterval> | null = null;

				function getPerView() {
					if (!config.perView) return 1;
					const w = window.innerWidth;
					if (w <= 600) return config.perView.mobile || 1;
					if (w <= 900) return config.perView.tablet || 2;
					return config.perView.desktop || 3;
				}

				function getMaxPage() {
					return Math.max(0, total - getPerView());
				}

				function goTo(i: number) {
					const max = getMaxPage();
					if (i > max) i = 0;
					if (i < 0) i = max;
					current = i;
					const pv = getPerView();
					const shift = (100 / pv) * current;
					track!.style.transform = 'translateX(-' + shift + '%)';
					if (counterEl) {
						const currentPage = Math.floor(current / pv) + 1;
						const totalPages = Math.ceil(total / pv);
						counterEl.textContent = currentPage + ' / ' + totalPages;
					}
				}

				function step() {
					const pv = getPerView();
					goTo(current + pv);
				}

				function stepBack() {
					const pv = getPerView();
					goTo(current - pv);
				}

				function startAuto() {
					stopAuto();
					if (config.autoplay) {
						timer = setInterval(function() { step(); }, config.autoplay);
					}
				}

				function stopAuto() {
					if (timer) { clearInterval(timer); timer = null; }
				}

				prevBtn.addEventListener('click', function() { stepBack(); stopAuto(); startAuto(); });
				nextBtn.addEventListener('click', function() { step(); stopAuto(); startAuto(); });

				// Swipe táctil
				let startX = 0;
				track.addEventListener('touchstart', function(e) {
					startX = (e as TouchEvent).changedTouches[0].screenX; stopAuto();
				}, { passive: true });
				track.addEventListener('touchend', function(e) {
					const diff = startX - (e as TouchEvent).changedTouches[0].screenX;
					if (Math.abs(diff) > 50) {
						if (diff > 0) step(); else stepBack();
					}
					startAuto();
				}, { passive: true });

				// Pausar al hacer hover
				const wrapper = track.closest('.slider-wrapper') || track.parentElement;
				if (wrapper) {
					wrapper.addEventListener('mouseenter', stopAuto);
					wrapper.addEventListener('mouseleave', startAuto);
				}

				// Ajustar slide widths para multi-view
				function applyWidths() {
					const pv = getPerView();
					slides.forEach(function(s) {
						s.style.minWidth = (100 / pv) + '%';
					});
					if (current > getMaxPage()) current = getMaxPage();
					goTo(current);
				}

				let resizeT: ReturnType<typeof setTimeout>;
				window.addEventListener('resize', function() {
					clearTimeout(resizeT);
					resizeT = setTimeout(applyWidths, 150);
				});

				// Init
				applyWidths();
				startAuto();
			}

			/* ——— Slider de Sectores (1 por página) ——— */
			createBookSlider({
				trackId: 'sectorSlider',
				prevId: 'sectorPrev',
				nextId: 'sectorNext',
				counterId: 'sliderCounter',
				slideSelector: '.slider-slide',
				autoplay: 5000
			});
		});
	</script>

