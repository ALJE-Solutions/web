---
<footer class="footer">
  <div class="footer-links">
    <a href="/privacidad">Política de Privacidad</a>
    <a href="/terminos">Términos de Servicio</a>
  </div>
  <div class="footer-brand">
    <img src="/src/images/logo_sinfondo.png" alt="ALJE Solutions Logo" class="footer-logo" loading="lazy" />
    <span>ALJE Solutions</span>
  </div>
  <div class="footer-copy">
    © {new Date().getFullYear()} ALJE Solutions. Todos los derechos reservados.
  </div>

  <style>
    .footer {
      background: var(--primary);
      color: #fff;
      text-align: center;
      padding: 2rem 0 1rem 0;
      margin-top: 3rem;
      font-size: 1rem;
      letter-spacing: 1px;
      box-shadow: 0 -2px 8px rgba(15,168,130,0.04);
    }
    .footer-links {
      margin-bottom: 1.2rem;
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
    }
    .footer-links a {
      color: var(--accent);
      text-decoration: none;
      font-weight: 600;
      font-size: 1rem;
      transition: color var(--transition);
    }
    .footer-links a:hover {
      color: #fff;
      text-decoration: underline;
    }
    .footer-brand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.7rem;
      font-weight: 700;
      font-size: 1.2rem;
      color: var(--accent);
      margin-bottom: 1.2rem;
    }
    .footer-logo {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: #fff;
      box-shadow: 0 2px 8px rgba(15,168,130,0.10);
      object-fit: contain;
    }
    .footer-copy {
      color: #fff;
      font-size: 1rem;
      margin-top: 0.5rem;
      letter-spacing: 1px;
    }
    @media (max-width: 600px) {
      .footer-links {
        gap: 1rem;
        font-size: 0.95rem;
      }
      .footer-brand {
        font-size: 1rem;
      }
      .footer-logo {
        width: 28px;
        height: 28px;
      }
    }
  </style>
</footer>
