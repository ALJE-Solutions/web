---
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-col">
      <div class="footer-brand">
        <img src="/logo_sinfondo.png" alt="ALJE Solutions Logo" class="footer-logo" loading="lazy" />
        <span>ALJE Solutions</span>
      </div>
      <p class="footer-desc">Transformamos ideas en soluciones digitales. Desarrollo web, consultoría IT y automatización para impulsar tu negocio.</p>
    </div>
    <div class="footer-col">
      <h4>Navegación</h4>
      <ul>
        <li><a href="#inicio">Inicio</a></li>
        <li><a href="#servicios">Servicios</a></li>
        <li><a href="#nosotros">Nosotros</a></li>
        <li><a href="#proceso">Proceso</a></li>
        <li><a href="#contacto">Contacto</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Legal</h4>
      <ul>
        <li><a href="/privacidad">Política de Privacidad</a></li>
        <li><a href="/terminos">Términos de Servicio</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Contacto</h4>
      <ul>
        <li><a href="mailto:aljesolutions@gmail.com">aljesolutions@gmail.com</a></li>
        <li>España</li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {new Date().getFullYear()} ALJE Solutions. Todos los derechos reservados.</span>
  </div>

  <style>
    .footer {
      background: #f5f7fa;
      color: #555;
      padding: 4rem 2rem 0;
      margin-top: 0;
      font-size: 0.95rem;
      border-top: 1px solid rgba(10,25,47,0.08);
    }
    .footer-inner {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1.2fr;
      gap: 3rem;
      padding-bottom: 3rem;
    }
    .footer-col h4 {
      color: #0a192f;
      font-size: 0.9rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      margin-bottom: 1rem;
    }
    .footer-col ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .footer-col li {
      margin-bottom: 0.6rem;
    }
    .footer-col a {
      color: #555;
      text-decoration: none;
      transition: color 0.2s;
    }
    .footer-col a:hover {
      color: #0fa882;
    }
    .footer-brand {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      margin-bottom: 1rem;
    }
    .footer-brand span {
      font-weight: 800;
      font-size: 1.3rem;
      color: #0a192f;
      letter-spacing: 1px;
    }
    .footer-logo {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      object-fit: contain;
    }
    .footer-desc {
      color: #555;
      line-height: 1.7;
      font-size: 0.93rem;
    }
    .footer-bottom {
      border-top: 1px solid rgba(10,25,47,0.08);
      text-align: center;
      padding: 1.5rem 0;
      font-size: 0.85rem;
      color: #888;
    }
    @media (max-width: 768px) {
      .footer-inner {
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
      }
    }
    @media (max-width: 480px) {
      .footer-inner {
        grid-template-columns: 1fr;
        gap: 1.5rem;
      }
    }
  </style>
</footer>
