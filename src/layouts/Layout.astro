---
import Header from '../pages/header.astro';
import Footer from '../pages/footer.astro';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'AnD Code — Desarrollo Web Profesional | Diseño Web a Medida',
  description = 'AnD Code: agencia de desarrollo web, diseño web y soluciones digitales a medida para empresas en España. Creamos páginas web, tiendas online y automatizaciones. Contacta con AnD Code hoy.',
  keywords = 'AnD Code, desarrollo web, diseño web, páginas web profesionales, tiendas online, consultoría IT, automatización, soluciones digitales, agencia web España, crear página web empresa, diseño web a medida, desarrollo web España',
  canonical = Astro.url.href,
  ogImage = '/og-image.png',
  noindex = false,
} = Astro.props;

const siteName = 'AnD Code';
const siteUrl = 'https://aljesolutions.com';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Google Search Console -->
  <meta name="google-site-verification" content="m-E0RwpoYwHsFulCaO0DWty2mi0n8TIOZcPT-CSWjMM" />

  <!-- SEO Básico -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <link rel="canonical" href={canonical} />
  {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

  <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:image:alt" content={title} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="es_ES" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

  <!-- Tema y móvil -->
  <meta name="theme-color" content="#5B6BF5" />
  <meta name="author" content="AnD Code" />

  <!-- Fuentes -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Schema.org JSON-LD (Datos estructurados para Google) -->
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "AnD Code",
      "alternateName": "AnD Code",
      "url": siteUrl,
      "description": "Agencia de desarrollo web y soluciones digitales a medida para empresas en España.",
      "inLanguage": "es-ES"
    },
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "AnD Code",
      "alternateName": ["AnD Code", "AnD Code Desarrollo Web", "AnD Code Soluciones Digitales"],
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/logo_andcode.png`
      },
      "image": fullOgImage,
      "description": "AnD Code es una agencia especializada en desarrollo web, diseño web a medida, tiendas online, consultoría IT y automatización de procesos para empresas en España.",
      "email": "aljesolutions@gmail.com",
      "areaServed": [
        { "@type": "Country", "name": "España" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios AnD Code",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Desarrollo Web a Medida", "description": "Creación de páginas web profesionales y aplicaciones web personalizadas." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tiendas Online", "description": "Diseño y desarrollo de tiendas online y e-commerce optimizados para vender." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Consultoría IT", "description": "Asesoramiento tecnológico y consultoría IT para empresas que quieren crecer digitalmente." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Automatización de Procesos", "description": "Automatización de tareas y flujos de trabajo para aumentar la productividad empresarial." } }
        ]
      },
      "priceRange": "€€",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "ES"
      },
      "sameAs": []
    }
  ])} />
</head>
<body>

<Header />

<main>
  <slot />
</main>

<Footer />

<!-- ═══════════ COOKIE BANNER ═══════════ -->
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Aviso de cookies" aria-live="polite">
  <div class="cookie-inner">
    <div class="cookie-text">
      <p>
        Usamos cookies propias y de terceros para analizar el tráfico y mejorar tu experiencia. 
        Puedes aceptarlas todas o gestionar tus preferencias. 
        <a href="/privacidad">Más información</a>.
      </p>
    </div>
    <div class="cookie-actions">
      <button id="cookie-reject" class="cookie-btn cookie-btn-outline">Rechazar</button>
      <button id="cookie-accept" class="cookie-btn cookie-btn-primary">Aceptar todas</button>
    </div>
  </div>
</div>

<script>
  const COOKIE_KEY = 'alje_cookie_consent';
  const banner = document.getElementById('cookie-banner');

  function hideBanner() {
    banner?.classList.add('cookie-banner--hidden');
  }

  // Show only if no decision yet
  if (!localStorage.getItem(COOKIE_KEY)) {
    // Small delay so it slides in after page load
    setTimeout(() => banner?.classList.add('cookie-banner--visible'), 600);
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'accepted');
    hideBanner();
  });

  document.getElementById('cookie-reject')?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'rejected');
    hideBanner();
  });
</script>

</body>
</html>

<style>
  :root {
    --primary: #1c1c2e;
    --accent: #5B6BF5;
    --accent-dark: #4452d8;
    --accent-glow: rgba(91,107,245,0.10);
    --text: #1a1a2e;
    --text-secondary: #555;
    --bg: #ffffff;
    --bg-alt: #f5f7fa;
    --bg-card: #ffffff;
    --radius: 16px;
    --shadow: 0 4px 24px rgba(28,28,46,0.06);
    --transition: 0.3s cubic-bezier(.4,0,.2,1);
  }
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
    overflow-x: hidden;
  }
  main {
    min-height: 70vh;
    margin: 0 auto;
    padding: 0;
  }
  /* Pages that aren't index.astro need top padding for fixed header */
  main:not(:has(.hero)) {
    padding-top: 80px;
  }
  @media (max-width: 800px) {
    main { padding: 0; }
    main:not(:has(.hero)) { padding-top: 70px; }
  }

  /* ═══════════ COOKIE BANNER ═══════════ */
  .cookie-banner {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(calc(100% + 2rem));
    z-index: 9999;
    width: calc(100% - 3rem);
    max-width: 760px;
    background: #1c1c2e;
    border: 1px solid rgba(91,107,245,0.20);
    border-radius: 14px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.28);
    opacity: 0;
    transition: transform 0.45s cubic-bezier(.4,0,.2,1), opacity 0.45s ease;
    pointer-events: none;
  }
  .cookie-banner--visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: all;
  }
  .cookie-banner--hidden {
    transform: translateX(-50%) translateY(calc(100% + 2rem));
    opacity: 0;
    pointer-events: none;
  }
  .cookie-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.2rem 1.6rem;
    flex-wrap: wrap;
  }
  .cookie-text {
    flex: 1;
    min-width: 200px;
  }
  .cookie-text p {
    color: rgba(255,255,255,0.78);
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
    font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
  }
  .cookie-text a {
    color: #5B6BF5;
    text-decoration: none;
    font-weight: 600;
  }
  .cookie-text a:hover { text-decoration: underline; }
  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .cookie-btn {
    padding: 0.55rem 1.2rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    border: none;
    font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .cookie-btn:hover { transform: translateY(-1px); }
  .cookie-btn-primary {
    background: #5B6BF5;
    color: #fff;
    box-shadow: 0 4px 14px rgba(91,107,245,0.30);
  }
  .cookie-btn-primary:hover { background: #4452d8; }
  .cookie-btn-outline {
    background: transparent;
    color: rgba(255,255,255,0.70);
    border: 1px solid rgba(255,255,255,0.20);
  }
  .cookie-btn-outline:hover {
    background: rgba(255,255,255,0.07);
    color: #fff;
  }
  @media (max-width: 520px) {
    .cookie-inner { flex-direction: column; gap: 1rem; }
    .cookie-actions { width: 100%; }
    .cookie-btn { flex: 1; text-align: center; }
  }
</style>
