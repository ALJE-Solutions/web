---
import Header from '../pages/header.astro';
import Footer from '../pages/footer.astro';
import WaveDivider from '../components/WaveDivider.astro';

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
  /** Color de fondo de la última sección de la página, para que la ola
   * que precede al footer (siempre oscuro) conecte sin salto. Por
   * defecto blanco, que es el color con el que termina la mayoría de
   * páginas. */
  footerTopColor?: string;
}

const {
  title = 'AnD Code — Desarrollo Web Profesional | Diseño Web a Medida',
  description = 'AnD Code: agencia de desarrollo web, diseño web y soluciones digitales a medida para empresas en España. Creamos páginas web, tiendas online y automatizaciones.',
  keywords = 'AnD Code, desarrollo web, diseño web España, diseño web profesional, páginas web a medida, páginas web para empresas, web para pymes, agencia web España, crear página web, presupuesto web, tienda online, e-commerce, consultoría IT, automatización empresas, soluciones digitales, desarrollo web empresa, web corporativa, landing page, web para autónomos, precio página web, agencia digital España, desarrollo web Sanlúcar, desarrollo web Cádiz, desarrollo web Andalucía',

  canonical = Astro.url.href,
  ogImage = '/og-image.png',
  noindex = false,
  footerTopColor = '#ffffff',
} = Astro.props;

const siteName = 'AnD Code';
const siteUrl = 'https://andcode.es';
const siteUrlAlt = 'https://aljesolutions.com';
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO Básico -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <link rel="canonical" href={canonical} />
  {noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}

  <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:image:alt" content={title} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="es_ES" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.png?v=2" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png?v=2" />

  <!-- Tema y móvil -->
  <meta name="theme-color" content="#5B6BF5" />
  <meta name="author" content="AnD Code" />

  <!-- Google Search Console -->
  <meta name="google-site-verification" content="jU47XMCPAaOxm9TemanVmPOXy9xbSnd4AEsyccrT6Zw" />

  <!-- SEO Geolocalización (España) -->
  <meta name="geo.region" content="ES" />
  <meta name="geo.placename" content="España" />
  <meta name="language" content="Spanish" />
  <meta name="revisit-after" content="7 days" />

  <!-- Fuentes -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Schema.org JSON-LD (Datos estructurados para Google) -->
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "AnD Code",
      "alternateName": "AnD Code",
      "url": siteUrl,
      "description": "Agencia de desarrollo web y soluciones digitales a medida para empresas en España.",
      "inLanguage": "es-ES"
    },
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "AnD Code",
      "alternateName": ["AnD Code", "AnD Code Desarrollo Web", "AnD Code Soluciones Digitales"],
      "url": siteUrl,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteUrl}/logo_andcode.png`
      },
      "image": fullOgImage,
      "description": "AnD Code es una agencia especializada en desarrollo web, diseño web a medida, tiendas online, consultoría IT y automatización de procesos para empresas en España.",
      "email": "andcodeinfo@gmail.com",
      "areaServed": [
        { "@type": "Country", "name": "España" }
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios AnD Code",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Desarrollo Web a Medida", "description": "Creación de páginas web profesionales y aplicaciones web personalizadas." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Tiendas Online", "description": "Diseño y desarrollo de tiendas online y e-commerce optimizados para vender." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Consultoría IT", "description": "Asesoramiento tecnológico y consultoría IT para empresas que quieren crecer digitalmente." } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Automatización de Procesos", "description": "Automatización de tareas y flujos de trabajo para aumentar la productividad empresarial." } }
        ]
      },
      "priceRange": "€€",
      "address": {
        "@type": "PostalAddress",
        "addressCountry": "ES"
      },
      "sameAs": []
    }
  ])} />
</head>
<body>

<Header />

<main>
  <slot />
</main>

<WaveDivider topColor={footerTopColor} bottomColor="#1c1c2e" />
<Footer />

<!-- ═══════════ WHATSAPP BUTTON ═══════════ -->
<a href="https://wa.me/34638266952?text=Hola%2C%20me%20gustar%C3%ADa%20saber%20m%C3%A1s%20sobre%20vuestros%20servicios"
   target="_blank" rel="noopener noreferrer"
   class="whatsapp-fab" aria-label="Contactar por WhatsApp">
  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="currentColor">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<!-- ═══════════ CTA FLOTANTE ═══════════ -->
<a href="/#contacto" class="cta-fixed" id="ctaFixed">Solicita una auditoría gratuita</a>

<script>
  const ctaFixed = document.getElementById('ctaFixed');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 400) {
      ctaFixed?.classList.add('cta-fixed--visible');
    } else {
      ctaFixed?.classList.remove('cta-fixed--visible');
    }
  });
</script>

<!-- ═══════════ COOKIE BANNER ═══════════ -->
<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Aviso de cookies" aria-live="polite">
  <div class="cookie-inner">
    <div class="cookie-text">
      <p>
        Usamos cookies propias y de terceros para analizar el tráfico y mejorar tu experiencia. 
        Puedes aceptarlas todas o gestionar tus preferencias. 
        <a href="/privacidad">Más información</a>.
      </p>
    </div>
    <div class="cookie-actions">
      <button id="cookie-reject" class="cookie-btn cookie-btn-outline">Rechazar</button>
      <button id="cookie-accept" class="cookie-btn cookie-btn-primary">Aceptar todas</button>
    </div>
  </div>
</div>

<script>
  const COOKIE_KEY = 'alje_cookie_consent';
  const banner = document.getElementById('cookie-banner');

  function hideBanner() {
    banner?.classList.add('cookie-banner--hidden');
  }

  // Show only if no decision yet
  if (!localStorage.getItem(COOKIE_KEY)) {
    // Small delay so it slides in after page load
    setTimeout(() => banner?.classList.add('cookie-banner--visible'), 600);
  }

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'accepted');
    hideBanner();
  });

  document.getElementById('cookie-reject')?.addEventListener('click', () => {
    localStorage.setItem(COOKIE_KEY, 'rejected');
    hideBanner();
  });
</script>

</body>
</html>

<style>
  :root {
    --primary: #1c1c2e;
    --accent: #5B6BF5;
    --accent-dark: #4452d8;
    --accent-glow: rgba(91,107,245,0.10);
    --text: #1a1a2e;
    --text-secondary: #555;
    --bg: #ffffff;
    --bg-alt: #f5f7fa;
    --bg-card: #ffffff;
    --radius: 16px;
    --shadow: 0 4px 24px rgba(28,28,46,0.06);
    --transition: 0.3s cubic-bezier(.4,0,.2,1);
  }
  html {
    overflow-x: clip;
  }
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
    overflow-x: clip;
  }
  main {
    min-height: 70vh;
    margin: 0 auto;
    padding: 0;
  }
  /* Pages that aren't index.astro need top padding for the fixed header.
     Fuera de la home el header siempre está en su estado "scrolled"
     (compacto), así que el hueco debe coincidir con esa altura real
     (~58-64px) y no con la del header expandido de la home (~80px). */
  main:not(:has(.hero)) {
    padding-top: 64px;
  }
  @media (max-width: 800px) {
    main { padding: 0; }
    main:not(:has(.hero)) { padding-top: 64px; }
  }

  /* ═══════════ COOKIE BANNER ═══════════ */
  .cookie-banner {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%) translateY(calc(100% + 2rem));
    z-index: 9999;
    width: calc(100% - 3rem);
    max-width: 760px;
    background: #1c1c2e;
    border: 1px solid rgba(91,107,245,0.20);
    border-radius: 14px;
    box-shadow: 0 8px 48px rgba(0,0,0,0.28);
    opacity: 0;
    transition: transform 0.45s cubic-bezier(.4,0,.2,1), opacity 0.45s ease;
    pointer-events: none;
  }
  .cookie-banner--visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: all;
  }
  .cookie-banner--hidden {
    transform: translateX(-50%) translateY(calc(100% + 2rem));
    opacity: 0;
    pointer-events: none;
  }
  .cookie-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.2rem 1.6rem;
    flex-wrap: wrap;
  }
  .cookie-text {
    flex: 1;
    min-width: 200px;
  }
  .cookie-text p {
    color: rgba(255,255,255,0.78);
    font-size: 0.88rem;
    line-height: 1.6;
    margin: 0;
    font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
  }
  .cookie-text a {
    color: #5B6BF5;
    text-decoration: none;
    font-weight: 600;
  }
  .cookie-text a:hover { text-decoration: underline; }
  .cookie-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .cookie-btn {
    padding: 0.55rem 1.2rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 700;
    cursor: pointer;
    border: none;
    font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .cookie-btn:hover { transform: translateY(-1px); }
  .cookie-btn-primary {
    background: #5B6BF5;
    color: #fff;
    box-shadow: 0 4px 14px rgba(91,107,245,0.30);
  }
  .cookie-btn-primary:hover { background: #4452d8; }
  .cookie-btn-outline {
    background: transparent;
    color: rgba(255,255,255,0.70);
    border: 1px solid rgba(255,255,255,0.20);
  }
  .cookie-btn-outline:hover {
    background: rgba(255,255,255,0.07);
    color: #fff;
  }
  @media (max-width: 520px) {
    .cookie-inner { flex-direction: column; gap: 1rem; }
    .cookie-actions { width: 100%; }
    .cookie-btn { flex: 1; text-align: center; }
  }

  /* ═══════════ WHATSAPP FAB ═══════════ */
  .whatsapp-fab {
    position: fixed;
    bottom: 2rem;
    right: 1.5rem;
    z-index: 9000;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25D366;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 20px rgba(37,211,102,0.45);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
  }
  .whatsapp-fab:hover {
    transform: scale(1.10);
    box-shadow: 0 6px 28px rgba(37,211,102,0.60);
  }

  /* ═══════════ CTA FIJO ═══════════ */
  .cta-fixed {
    position: fixed;
    bottom: 2rem;
    left: 1.5rem;
    z-index: 9000;
    background: #5B6BF5;
    color: #fff;
    font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
    font-size: 0.88rem;
    font-weight: 700;
    padding: 0.75rem 1.35rem;
    border-radius: 50px;
    text-decoration: none;
    box-shadow: 0 4px 20px rgba(91,107,245,0.40);
    opacity: 0;
    transform: translateY(12px);
    pointer-events: none;
    transition: opacity 0.3s, transform 0.3s, background 0.2s;
    white-space: nowrap;
  }
  .cta-fixed--visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }
  .cta-fixed:hover { background: #4452d8; }

  @media (max-width: 600px) {
    .cta-fixed {
      font-size: 0.8rem;
      padding: 0.65rem 1rem;
      left: 1rem;
      bottom: 1.5rem;
      max-width: calc(100vw - 90px);
    }
    .whatsapp-fab {
      bottom: 1.5rem;
      right: 1rem;
      width: 50px;
      height: 50px;
    }
  }
</style>
