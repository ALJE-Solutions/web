---
import Header from '../pages/header.astro';
import Footer from '../pages/footer.astro';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ALJE Solutions — Desarrollo Web y Soluciones Digitales</title>
  <meta name="description" content="Agencia de desarrollo web y soluciones digitales a medida. Desarrollo web, consultoría IT y automatización en España." />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
</head>
<body>

<Header />

<main>
  <slot />
</main>

<Footer />

</body>
</html>

<style>
  :root {
    --primary: #0a192f;
    --accent: #0fa882;
    --accent-dark: #0a8a6a;
    --accent-glow: rgba(15,168,130,0.10);
    --text: #1a1a2e;
    --text-secondary: #555;
    --bg: #ffffff;
    --bg-alt: #f5f7fa;
    --bg-card: #ffffff;
    --radius: 16px;
    --shadow: 0 4px 24px rgba(10,25,47,0.06);
    --transition: 0.3s cubic-bezier(.4,0,.2,1);
  }
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    height: 100%;
    font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }
  main {
    min-height: 70vh;
    margin: 0 auto;
    padding: 0;
  }
  @media (max-width: 800px) {
    main { padding: 0; }
  }
</style>
</style>
